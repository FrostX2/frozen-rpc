{
  "name": "frozen-rpc",
  "version": "1.0.0",
  "description": "Cross-platform desktop Discord Rich Presence injector",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "bash build-installers.sh",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac",
    "dist:flatpak": "bash flatpak/build.sh",
    "dist:all": "bash build-installers.sh"
  },
  "keywords": ["discord", "rpc", "rich-presence", "electron", "desktop"],
  "license": "MIT",
  "author": "NotFrost <notfrost@users.noreply.github.com>",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "discord-rpc": "^4.0.1",
    "dotenv": "^16.4.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.frozenrpc.app",
    "productName": "Frozen RPC",
    "directories": {
      "output": "../installer"
    },
    "files": [
      "src/**/*",
      "renderer/**/*",
      "assets/**/*",
      "config/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Frozen RPC",
      "runAfterFinish": true,
      "artifactName": "Frozen-RPC-Setup-${version}.${ext}"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage",
        "deb",
        "rpm",
        {
          "target": "pacman",
          "arch": ["x64"],
          "artifactName": "${name}-${version}.pkg.tar.zst"
        }
      ],
      "category": "Network",
      "synopsis": "Discord Rich Presence injector",
      "description": "Cross-platform desktop app for custom Discord Rich Presence with OAuth2 injection.",
      "maintainer": "NotFrost <notfrost@users.noreply.github.com>"
    },
    "mac": {
      "icon": "assets/icon.png",
      "target": ["dmg", "pkg"],
      "category": "public.app-category.utilities"
    }
  }
}
